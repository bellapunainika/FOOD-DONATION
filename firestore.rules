rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles — public READ so the homepage map shows all donors/orgs/volunteers
    // to anyone visiting the site. Only the owner can write their own profile.
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Donations — public READ so leaderboards are visible to everyone.
    // Only authenticated users can create/update/delete.
    match /donations/{donationId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.donorId == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
  }
}
