rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles — only the owner can write; anyone logged in can read
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Donations — PUBLIC read so leaderboards are visible to everyone.
    // Only authenticated users can create/update/delete.
    match /donations/{donationId} {
      allow read: if true;                                                    // public
      allow create: if request.auth != null && request.resource.data.donorId == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
  }
}
