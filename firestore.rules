rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read/write their own profile, except reading basic info
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Donations: anyone logged in can read. Donors can create. Anyone can update (for accepting/delivering).
    match /donations/{donationId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.donorId == request.auth.uid;
      // In a strict prod environment, we would validate that only organizationss can set reservedByorganizationsId
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Deliveries: real-time tracking documents
    match /deliveries/{deliveryId} {
      // Any authenticated user can read (donor reads their own via query filters)
      allow read: if request.auth != null;
      // Only the assigned handler (org or volunteer) can create
      allow create: if request.auth != null
        && (request.resource.data.organizationId == request.auth.uid
            || request.resource.data.volunteerId == request.auth.uid);
      // Only the assigned handler can update location
      allow update: if request.auth != null
        && (resource.data.organizationId == request.auth.uid
            || resource.data.volunteerId == request.auth.uid);
    }
  }
}
